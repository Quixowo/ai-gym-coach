# Secrets — never commit
.env

# Markdown: local working docs stay untracked — only READMEs are committed
*.md
!README*.md

# Knowledge base content is authored and ingested locally, never committed
knowledge_base/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
*.egg

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
